# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/maidmatch

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================
# RAZORPAY PAYMENT GATEWAY CONFIGURATION
# ============================================
# Get these from your Razorpay Dashboard:
# https://dashboard.razorpay.com/app/dashboard

# Test Key ID (starts with rzp_test_)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Test Key Secret (DO NOT share this!)
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Webhook Secret (from Razorpay Webhooks settings)
# Used to verify webhook authenticity
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# ============================================
# COMMISSION SETTINGS
# ============================================
# Platform commission rate (0.15 = 15%)
# Worker receives: amount * (1 - COMMISSION_RATE)
COMMISSION_RATE=0.15

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# Your frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
